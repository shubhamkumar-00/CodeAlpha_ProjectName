<!-- CONTACT -->
<section id="contact" style="padding-top:5rem; padding-bottom:5rem;">
  <p class="section-tag">Get In Touch</p>
  <h2 class="section-title" style="color:var(--bg)">Let's build something<br/><em>amazing</em> together</h2>
  <div class="contact-grid">
    <div class="contact-info">
      <p>I'm currently open to freelance opportunities and internships. Whether you have a project in mind or just want to say hi — my inbox is always open!</p>
      <div class="contact-links">
        <a href="mailto:alex@example.com" class="contact-link"><span>✉️</span> alex@example.com</a>
