<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portfolio | CodeAlpha</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,300&family=Syne:wght@400;600;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #f5f1eb;
      --dark: #1a1714;
      --accent: #c0392b;
      --accent2: #e74c3c;
      --muted: #8a8178;
      --border: #ddd8d0;
      --card-bg: #fff;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Syne', sans-serif;
      background: var(--bg);
      color: var(--dark);
      overflow-x: hidden;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.2rem 3rem;
      background: rgba(245,241,235,0.9);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }

    .logo {
      font-size: 1.4rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--dark);
    }

    .logo span { color: var(--accent); }

    nav ul { list-style: none; display: flex; gap: 2.5rem; }
    nav a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 600;
      transition: color 0.2s;
    }
    nav a:hover { color: var(--dark); }

    /* HERO */
    #hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 0 3rem;
      position: relative;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      top: -10%; right: -5%;
      width: 60%;
      height: 110%;
      background: linear-gradient(135deg, var(--dark) 0%, #2d2520 100%);
      clip-path: polygon(20% 0%, 100% 0%, 100% 100%, 0% 100%);
      z-index: 0;
    }

    .hero-content {
      position: relative;
      z-index: 1;
      max-width: 600px;
    }

    .hero-tag {
      font-size: 0.8rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
      font-weight: 600;
    }

    .hero-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3.5rem, 7vw, 6rem);
      font-weight: 300;
      line-height: 1.05;
      color: var(--dark);
      margin-bottom: 1rem;
    }

    .hero-name em {
      font-style: italic;
      color: var(--muted);
    }

    .hero-role {
      font-size: 1rem;
      color: var(--muted);
      font-weight: 400;
      margin-bottom: 2.5rem;
      letter-spacing: 0.02em;
    }

    .hero-btns {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-block;
      padding: 0.85rem 2rem;
      border-radius: 4px;
      font-family: 'Syne', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.25s ease;
      border: none;
    }

    .btn-primary {
      background: var(--accent);
      color: #fff;
    }
    .btn-primary:hover { background: var(--accent2); transform: translateY(-2px); }

    .btn-outline {
      background: transparent;
      color: var(--dark);
      border: 2px solid var(--dark);
    }
    .btn-outline:hover { background: var(--dark); color: var(--bg); }

    .hero-stats {
      position: absolute;
      right: 4rem;
      bottom: 4rem;
      z-index: 1;
      display: flex;
      gap: 2.5rem;
    }

    .stat { text-align: center; }
    .stat-num {
      font-size: 2.2rem;
      font-weight: 800;
      color: var(--bg);
      display: block;
    }
    .stat-label {
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(245,241,235,0.5);
    }

    /* SECTIONS */
    section {
      padding: 6rem 3rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-tag {
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
      margin-bottom: 0.8rem;
    }

    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 300;
      margin-bottom: 3rem;
      line-height: 1.15;
    }

    /* ABOUT */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 4rem;
      align-items: center;
    }

    .about-img-box {
      position: relative;
    }

    .about-img {
      width: 100%;
      aspect-ratio: 4/5;
      object-fit: cover;
      border-radius: 6px;
      display: block;
      background: var(--dark);
    }

    .about-img-placeholder {
      width: 100%;
      aspect-ratio: 4/5;
      background: linear-gradient(135deg, #2d2520 0%, #1a1714 100%);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 5rem;
    }

    .about-deco {
      position: absolute;
      bottom: -1.5rem; right: -1.5rem;
      width: 80%;
      height: 80%;
      border: 2px solid var(--accent);
      border-radius: 6px;
      z-index: -1;
    }

    .about-text p {
      color: var(--muted);
      line-height: 1.85;
      margin-bottom: 1.2rem;
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      font-weight: 300;
    }

    .skills-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-top: 1.5rem;
    }

    .skill-tag {
      background: var(--dark);
      color: var(--bg);
      padding: 0.35rem 0.9rem;
      border-radius: 3px;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      font-weight: 600;
    }

    /* PROJECTS */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.5rem;
    }

    .project-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .project-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.12);
    }

    .project-thumb {
      height: 200px;
      background: linear-gradient(135deg, var(--dark), #3a3028);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3.5rem;
      position: relative;
      overflow: hidden;
    }

    .project-thumb::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom right, rgba(192,57,43,0.3), transparent);
    }

    .project-info { padding: 1.5rem; }

    .project-info h3 {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .project-info p {
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.6;
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem;
    }

    .project-tags {
      display: flex;
      gap: 0.4rem;
      margin-top: 1rem;
      flex-wrap: wrap;
    }

    .project-tag {
      font-size: 0.72rem;
      color: var(--accent);
      border: 1px solid var(--accent);
      padding: 0.2rem 0.6rem;
      border-radius: 3px;
      letter-spacing: 0.04em;
      font-weight: 600;
    }

    /* CONTACT */
    #contact { background: var(--dark); color: var(--bg); border-radius: 16px; margin: 0 2rem 4rem; padding: 5rem 4rem; max-width: none; }
    #contact .section-title { color: var(--bg); }
    #contact .section-tag { color: var(--accent); }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }

    .contact-info p {
      color: rgba(245,241,235,0.6);
      line-height: 1.8;
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      margin-bottom: 2rem;
    }

    .contact-links { display: flex; flex-direction: column; gap: 0.8rem; }
    .contact-link {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      color: rgba(245,241,235,0.7);
      text-decoration: none;
      font-size: 0.9rem;
      transition: color 0.2s;
    }
    .contact-link:hover { color: var(--accent); }
    .contact-link span { font-size: 1.2rem; }

    .contact-form { display: flex; flex-direction: column; gap: 1rem; }

    .form-group input,
    .form-group textarea {
      width: 100%;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 6px;
      color: var(--bg);
      font-family: 'Syne', sans-serif;
      font-size: 0.9rem;
      padding: 0.9rem 1.1rem;
      outline: none;
      transition: border-color 0.2s;
    }
    .form-group input:focus,
    .form-group textarea:focus { border-color: var(--accent); }
    .form-group input::placeholder,
    .form-group textarea::placeholder { color: rgba(245,241,235,0.3); }
    .form-group textarea { min-height: 120px; resize: vertical; }

    footer {
      text-align: center;
      padding: 2rem;
      color: var(--muted);
      font-size: 0.8rem;
      letter-spacing: 0.05em;
    }

    .hamburger { display: none; }

    @media (max-width: 768px) {
      nav { padding: 1rem 1.5rem; }
      nav ul { display: none; }
      section { padding: 4rem 1.5rem; }
      #hero { padding: 0 1.5rem; min-height: auto; padding-top: 8rem; padding-bottom: 4rem; }
      .hero-bg { display: none; }
      .hero-stats { position: static; margin-top: 3rem; justify-content: flex-start; }
      .stat-num { color: var(--dark); }
      .stat-label { color: var(--muted); }
      .about-grid { grid-template-columns: 1fr; }
      .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
      #contact { margin: 0 1rem 2rem; padding: 3rem 2rem; }
    }
  </style>
</head>
<body>

<nav>
  <div class="logo">Alex<span>.</span>Dev</div>
  <ul>
    <li><a href="#about">About</a></li>
